{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptologik.dev/schemas/findings.schema.json",
  "title": "cryptologik Findings Report",
  "description": "Machine-readable schema for CLI JSON findings output.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "findings"
  ],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "category",
          "severity",
          "message",
          "location",
          "recommendation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "location": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
