# cryptologik — Environment Configuration Template
# =========================================================
# Copy this file to .env and configure for your environment.
# Never commit .env to version control.

# Assessment profile controls the depth and breadth of checks
# Options: minimal (fast, high-confidence only), standard (recommended), strict (all checks, more FPs)
ASSESSMENT_PROFILE=standard

# Target category to assess
# Options:
#   crypto_config    — Source code cryptographic configuration review
#   key_management   — Key management posture review
#   wallet           — Wallet security posture
#   smart_contract   — Smart contract security review
TARGET_CATEGORY=crypto_config  # crypto_config, key_management, wallet, smart_contract

# Smart contract framework mapping to use for findings
# Options:
#   swc   — Smart Contract Weakness Classification (https://swcregistry.io/)
#   scsvs — Smart Contract Security Verification Standard
#   both  — Include mappings from both frameworks
FRAMEWORK_MODE=swc  # swc, scsvs, both

# Enable wallet-specific security checks
# (offline storage, seed phrase handling, hardware wallet requirements)
INCLUDE_WALLET_CHECKS=false

# Enable custody-specific checks
# (multi-party authorization, cold storage policy, HSM requirements)
INCLUDE_CUSTODY_CHECKS=false

# Enable smart contract code review checks
INCLUDE_CONTRACT_REVIEW=false

# Strictness controls the minimum confidence threshold for reporting findings
# Options:
#   minimal  — Only critical-confidence findings
#   standard — High and critical findings (recommended for most use cases)
#   strict   — All findings including low-confidence (expect more false positives)
STRICTNESS=standard  # minimal, standard, strict

# Output directory for generated reports and finding exports
OUTPUT_DIR=./output

# Report detail level
# Options: minimal (finding list only), standard (with context), verbose (full technical detail)
REPORT_VERBOSITY=standard
